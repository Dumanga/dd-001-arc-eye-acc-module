  PURCHASE
  BOTH
}

enum TaxCalculationMethod {
  PERCENTAGE
  FIXED_AMOUNT
}

enum TaxApplicableOn {
  GOODS
  SERVICES
  BOTH
}

enum AccountingUomCategoryCode {
  AREA
  LENGTH
  TIME
  UNIT
  VOLUME
  WEIGHT
}

