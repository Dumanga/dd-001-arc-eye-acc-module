// POS bill lifecycle. Per accounting-theories.md § 7 and
// pos-integration-flow.md § 4.2 — a single entity with status
// covering live cart (DRAFT, isHeld=false), held bill (DRAFT,
// isHeld=true), posted bill (COMPLETED), and abandoned/deleted
// bill (CANCELLED). No separate Cart table.
enum AccountingPosBillStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

// Bill-level summary of how the customer paid. Stored on the bill
// row for list-view rendering and reporting; the actual
// payment-row breakdown lives on AccountingPosBillPayment.
//   CASH    - one cash account, immediate settle
//   CARD    - one card-merchant cash-equivalent account, immediate settle
//   MIXED   - two cash/cash-equivalent rows on the bill-payment table
//   SPLIT   - merchant-deferred (merchantClientId required), no JE 4
enum AccountingPosBillSummaryMethod {
  CASH
  CARD
  MIXED
  SPLIT
}

// Per-row tender method on AccountingPosBillPayment. Mixed bills
// have two CASH (or CASH+CARD) rows with different cashAccountIds.
// REDEEM_VOUCHER (theory § 7.4) clears a voucher serial as payment —
// the row carries `voucherSerialId` and posts a debit to the voucher
// product's liability account instead of cash.
enum AccountingPosBillTenderMethod {
  CASH
  CARD
  SPLIT
  REDEEM_VOUCHER
}

enum AccountingJournalDocType {
  GRN
  GRR
  PV
  INV
  SR
  RC
  POS
  JE
  IBT
  EXP
  JEV
  MIN
}

enum AccountingExpenseVoucherStatus {
  DRAFT
  APPROVED
  CANCELLED
}

enum AccountingJournalVoucherStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum AccountingMaterialIssueStatus {
  DRAFT
  APPROVED
  CANCELLED
}

enum AccountingSystemAccountKey {
  SUPPLIER_PAYABLE
  DEBTOR_RECEIVABLE
  PRODUCTION_INVENTORY
  CASH_ON_HAND
  SSCL_TAX_PAYABLE
  VAT_PAYABLE
  PRODUCT_INCOME
  CASH_DISCOUNT_INCOME
  SALES_DISCOUNT_INCOME
  COST_OF_GOODS_SOLD
  SALES_DISCOUNT_EXPENSE
  CASH_DISCOUNT_EXPENSE
}

enum RepairStatus {
  PENDING
  PROCESSING
  REPAIR_COMPLETED
  DELIVERED
}

enum RepairIntakeType {
  WALK_IN
  COURIER
}

enum SmsStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id              String     @id @default(cuid())
  username        String     @unique
  displayName     String
  passwordHash    String
  role            UserRole
  system          UserSystem @default(OPERATION)
  profileImageId  Int        @default(1)
  accessDashboard Boolean    @default(false)
  accessRepairs   Boolean    @default(false)
  accessClients   Boolean    @default(false)
  accessBrands    Boolean    @default(false)
  accessUsers     Boolean    @default(false)
  accessStores    Boolean    @default(false)
  accessSms       Boolean    @default(false)
  accessSettings  Boolean    @default(false)
  storeId         String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  sessions       Session[]
  store          Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  repairsCreated Repair[]
  repairAudits   RepairAudit[]

  @@index([system])
  @@index([storeId])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model AccountingUser {
  id              String             @id @default(cuid())
  username        String             @unique
  displayName     String
  passwordHash    String
  role            AccountingUserRole
  profileImageId  Int                @default(1)
  storeId         String?
  accessDashboard Boolean            @default(false)
  accessSuppliers Boolean            @default(false)
  accessCustomers Boolean            @default(false)
  accessInventory Boolean            @default(false)
  accessAccounts  Boolean            @default(false)
  accessReports   Boolean            @default(false)
  accessPos       Boolean            @default(false)
  accessSettings  Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  sessions                        AccountingSession[]
  store                           Store?                             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdUoms                     AccountingUom[]
  purchaseOrders                  AccountingPurchaseOrder[]
  goodsReceipts                   AccountingGoodsReceipt[]           @relation("GoodsReceiptCreatedBy")
  approvedGrns                    AccountingGoodsReceipt[]           @relation("GoodsReceiptApprovedBy")
  paymentVouchers                 AccountingPaymentVoucher[]         @relation("PaymentVoucherCreatedBy")
  approvedPaymentVouchers         AccountingPaymentVoucher[]         @relation("PaymentVoucherApprovedBy")
  expenseVouchers                 AccountingExpenseVoucher[]         @relation("ExpenseVoucherCreatedBy")
  approvedExpenseVouchers         AccountingExpenseVoucher[]         @relation("ExpenseVoucherApprovedBy")
  journalVouchers                 AccountingJournalVoucher[]         @relation("JournalVoucherCreatedBy")
  postedJournalVouchers           AccountingJournalVoucher[]         @relation("JournalVoucherPostedBy")
  materialIssues                  AccountingMaterialIssue[]          @relation("MaterialIssueCreatedBy")
  approvedMaterialIssues          AccountingMaterialIssue[]          @relation("MaterialIssueApprovedBy")
  goodsReturns                    AccountingGoodsReturn[]            @relation("GoodsReturnCreatedBy")
  approvedGoodsReturns            AccountingGoodsReturn[]            @relation("GoodsReturnApprovedBy")
  journalEntries                  AccountingJournalEntry[]
  supplierLedgerEntries           AccountingSupplierLedgerEntry[]
  customerLedgerEntries           AccountingCustomerLedgerEntry[]
  createdClients                  AccountingClient[]                 @relation("AccountingClientCreatedBy")
  createdQuotations               AccountingQuotation[]              @relation("QuotationCreatedBy")
  approvedQuotations              AccountingQuotation[]              @relation("QuotationApprovedBy")
  createdInvoices                 AccountingInvoice[]                @relation("InvoiceCreatedBy")
  approvedInvoices                AccountingInvoice[]                @relation("InvoiceApprovedBy")
  createdCustomerPaymentReceipts  AccountingCustomerPaymentReceipt[] @relation("CustomerPaymentReceiptCreatedBy")
  approvedCustomerPaymentReceipts AccountingCustomerPaymentReceipt[] @relation("CustomerPaymentReceiptApprovedBy")
  createdCustomerReturns          AccountingCustomerReturn[]         @relation("CustomerReturnCreatedBy")
  approvedCustomerReturns         AccountingCustomerReturn[]         @relation("CustomerReturnApprovedBy")
  posBills                        AccountingPosBill[]                @relation("PosBillCashier")

  @@index([storeId])
  @@map("accountinguser")
}

model AccountingSession {
  id               String   @id @default(cuid())
  tokenHash        String   @unique
  accountingUserId String
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  accountingUser AccountingUser @relation(fields: [accountingUserId], references: [id], onDelete: Cascade)

  @@map("accountingsession")
}

model AccountingAccountCategory {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String   @unique
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accountTypes  AccountingAccountType[]
  chartAccounts ChartOfAccount[]

  @@index([displayOrder])
  @@index([isActive, displayOrder])
  @@map("accountingaccountcategory")
}

model AccountingAccountType {
  id               String   @id @default(cuid())
  categoryId       String
  code             String
  name             String
  description      String?
  displayOrder     Int      @default(0)
  requiresCurrency Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category        AccountingAccountCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  accountSubtypes AccountingAccountSubtype[]
  chartAccounts   ChartOfAccount[]

  @@unique([categoryId, code])
  @@unique([categoryId, name])
  @@index([categoryId, displayOrder])
  @@index([isActive, categoryId, displayOrder])
  @@map("accountingaccounttype")
}

model AccountingAccountSubtype {
  id           String   @id @default(cuid())
  typeId       String
  code         String
  name         String
  description  String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  type          AccountingAccountType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  chartAccounts ChartOfAccount[]

  @@unique([typeId, code])
  @@unique([typeId, name])
  @@index([typeId, displayOrder])
  @@index([isActive, typeId, displayOrder])
  @@map("accountingaccountsubtype")
}

model ChartOfAccount {
  id           String   @id @default(cuid())
  categoryId   String
  typeId       String
  subtypeId    String
  code         String   @unique
  name         String
  currencyCode String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category                    AccountingAccountCategory          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  type                        AccountingAccountType              @relation(fields: [typeId], references: [id], onDelete: Restrict)
  subtype                     AccountingAccountSubtype           @relation(fields: [subtypeId], references: [id], onDelete: Restrict)
  outputTaxCodes              TaxCode[]                          @relation("OutputTaxAccount")
  inputTaxCodes               TaxCode[]                          @relation("InputTaxAccount")
  inventoryProducts           AccountingProduct[]                @relation("ProductInventoryAccount")
  cogsProducts                AccountingProduct[]                @relation("ProductCogsAccount")
  incomeProducts              AccountingProduct[]                @relation("ProductIncomeAccount")
  payFromVouchers             AccountingPaymentVoucher[]         @relation("PaymentVoucherPayFromAccount")
  receiveToReceipts           AccountingCustomerPaymentReceipt[] @relation("CustomerPaymentReceiveToAccount")
  journalEntries              AccountingJournalEntry[]
  systemAccount               AccountingSystemAccount?
  posBillsAsPrimaryCash       AccountingPosBill[]                @relation("PosBillPrimaryCashAccount")
  posBillPayments             AccountingPosBillPayment[]         @relation("PosBillPaymentCashAccount")
  openingBalanceGoodsReceipts AccountingGoodsReceipt[]           @relation("GoodsReceiptOpeningEquityAccount")
  payFromExpenseVouchers      AccountingExpenseVoucher[]         @relation("ExpenseVoucherPayFromAccount")
  expenseVoucherLines         AccountingExpenseVoucherLine[]     @relation("ExpenseVoucherLineAccount")
  journalVoucherLines         AccountingJournalVoucherLine[]     @relation("JournalVoucherLineAccount")
  materialIssues              AccountingMaterialIssue[]          @relation("MaterialIssueExpenseAccount")

  @@index([categoryId, typeId, subtypeId])
  @@index([subtypeId, code])
  @@index([isActive, categoryId])
  @@map("chartofaccounts")
}

model TaxCode {
  id                 String               @id @default(cuid())
  code               String               @unique
  name               String
  taxType            TaxCodeType
  calculation        TaxCalculationMethod
  rate               Decimal              @db.Decimal(14, 4)
  outputTaxAccountId String?
  inputTaxAccountId  String?
  applicableOn       TaxApplicableOn
  effectiveFrom      DateTime
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  outputTaxAccount ChartOfAccount?             @relation("OutputTaxAccount", fields: [outputTaxAccountId], references: [id], onDelete: SetNull)
  inputTaxAccount  ChartOfAccount?             @relation("InputTaxAccount", fields: [inputTaxAccountId], references: [id], onDelete: SetNull)
  supplierLinks    AccountingSupplierTaxCode[]

  @@index([taxType, isActive])
  @@index([effectiveFrom])
  @@index([outputTaxAccountId])
  @@index([inputTaxAccountId])
  @@map("accountingtaxcode")
}

model AccountingSupplier {
  id                      String   @id @default(cuid())
  code                    String   @unique
  name                    String
  email                   String
  primaryPhoneCountryCode String
  primaryPhoneDialCode    String
  primaryPhoneLocalNumber String
  internalNotes           String?  @db.Text
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  contactInfo       AccountingSupplierContactInfo?
  salesInfo         AccountingSupplierSalesInfo?
  taxCodes          AccountingSupplierTaxCode[]
  salesContacts     AccountingSupplierSalesContact[]
  bankAccounts      AccountingSupplierBankAccount[]
  preferredProducts AccountingProductPreferredSupplier[]
  purchaseOrders    AccountingPurchaseOrder[]
  goodsReceipts     AccountingGoodsReceipt[]
  goodsReturns      AccountingGoodsReturn[]
  paymentVouchers   AccountingPaymentVoucher[]
  journalEntries    AccountingJournalEntry[]
  ledgerEntries     AccountingSupplierLedgerEntry[]

  @@index([name])
  @@index([email])
  @@index([createdAt])
  @@map("accountingsupplier")
}

model AccountingSupplierContactInfo {
  id                        String   @id @default(cuid())
  supplierId                String   @unique
  addressLine1              String?
  addressLine2              String?
  city                      String?
  country                   String?
  postalCode                String?
  alternatePhoneCountryCode String?
  alternatePhoneDialCode    String?
  alternatePhoneLocalNumber String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  supplier AccountingSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([country, city])
  @@map("accountingsuppliercontactinfo")
}

model AccountingSupplierSalesInfo {
  id           String   @id @default(cuid())
  supplierId   String   @unique
  currencyCode String   @default("LKR")
  tinNumber    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier AccountingSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([currencyCode])
  @@map("accountingsuppliersalesinfo")
}

model AccountingSupplierTaxCode {
  id           String   @id @default(cuid())
  supplierId   String
  taxCodeId    String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier AccountingSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  taxCode  TaxCode            @relation(fields: [taxCodeId], references: [id], onDelete: Cascade)

  @@unique([supplierId, taxCodeId])
  @@index([supplierId, displayOrder])
  @@index([taxCodeId, displayOrder])
  @@map("accountingsuppliertaxcode")
}

model AccountingSupplierSalesContact {
  id               String   @id @default(cuid())
  supplierId       String
  name             String
  email            String
  designation      String
  phoneCountryCode String
  phoneDialCode    String
  phoneLocalNumber String
  displayOrder     Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  supplier AccountingSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, displayOrder])
  @@index([email])
  @@map("accountingsuppliersalescontact")
}

model AccountingSupplierBankAccount {
  id            String   @id @default(cuid())
  supplierId    String
  accountNumber String
  bankName      String
  branchName    String
  displayOrder  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier AccountingSupplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId, displayOrder])
  @@map("accountingsupplierbankaccount")
}

model AccountingUomCategory {
  id                        String                    @id @default(cuid())
  code                      AccountingUomCategoryCode @unique
  name                      String                    @unique
  description               String?
  baseUnitName              String
  defaultSmallestAllowedQty Decimal                   @db.Decimal(18, 5)
  displayOrder              Int                       @default(0)
  isActive                  Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt

  units    AccountingUom[]
  products AccountingProduct[]

  @@index([displayOrder])
  @@index([isActive, displayOrder])
  @@map("accountinguomcategory")
}

model AccountingUom {
  id                 String   @id @default(cuid())
  categoryId         String
  name               String
  normalizedName     String
  ratioToBase        Decimal  @db.Decimal(18, 5)
  smallestAllowedQty Decimal  @db.Decimal(18, 5)
  isActive           Boolean  @default(true)
  isSystem           Boolean  @default(false)
  isBase             Boolean  @default(false)
  createdByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category      AccountingUomCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  createdByUser AccountingUser?       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([categoryId, normalizedName])
  @@index([categoryId, isActive, name])
  @@index([categoryId, isBase])
  @@index([createdByUserId])
  @@map("accountinguom")
}

model AccountingItemCategory {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products AccountingProduct[]

  @@index([name])
  @@map("accountingitemcategory")
}

model AccountingItemBrand {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products AccountingProduct[]

  @@index([name])
  @@map("accountingitembrand")
}

model AccountingItemModel {
  id             String   @id @default(cuid())
  name           String
  normalizedName String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products AccountingProduct[]

  @@index([name])
  @@map("accountingitemmodel")
}

model AccountingProduct {
  id                    String                     @id @default(cuid())
  itemType              AccountingProductItemType
  tradeMode             AccountingProductTradeMode @default(BOTH)
  code                  String                     @unique @db.VarChar(30)
  itemCategoryId        String?
  itemBrandId           String?
  itemModelId           String?
  purchaseName          String?                    @db.VarChar(200)
  costPrice             Decimal?                   @db.Decimal(18, 4)
  stockOnHand           Decimal                    @default(0) @db.Decimal(18, 4)
  uomCategoryId         String
  inventoryAccountId    String?
  cogsAccountId         String?
  serialTrackingEnabled Boolean                    @default(false)
  status                AccountingProductStatus    @default(ACTIVE)
  salesName             String?                    @db.VarChar(200)
  salesPrice            Decimal?                   @db.Decimal(18, 4)
  incomeAccountId       String?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  itemCategory        AccountingItemCategory?              @relation(fields: [itemCategoryId], references: [id], onDelete: SetNull)
  itemBrand           AccountingItemBrand?                 @relation(fields: [itemBrandId], references: [id], onDelete: SetNull)
  itemModel           AccountingItemModel?                 @relation(fields: [itemModelId], references: [id], onDelete: SetNull)
  uomCategory         AccountingUomCategory                @relation(fields: [uomCategoryId], references: [id], onDelete: Restrict)
  inventoryAccount    ChartOfAccount?                      @relation("ProductInventoryAccount", fields: [inventoryAccountId], references: [id], onDelete: Restrict)
  cogsAccount         ChartOfAccount?                      @relation("ProductCogsAccount", fields: [cogsAccountId], references: [id], onDelete: Restrict)
  incomeAccount       ChartOfAccount?                      @relation("ProductIncomeAccount", fields: [incomeAccountId], references: [id], onDelete: Restrict)
  preferredSuppliers  AccountingProductPreferredSupplier[]
  purchaseOrderLines  AccountingPurchaseOrderLine[]
  goodsReceiptLines   AccountingGoodsReceiptLine[]
  goodsReturnLines    AccountingGoodsReturnLine[]
  quotationLines      AccountingQuotationLine[]
  invoiceLines        AccountingInvoiceLine[]
  customerReturnLines AccountingCustomerReturnLine[]
  journalEntries      AccountingJournalEntry[]
  branchStock         AccountingProductStock[]
  posBillLines        AccountingPosBillLine[]
  materialIssueLines  AccountingMaterialIssueLine[]        @relation("MaterialIssueLineProduct")

  @@index([purchaseName])
  @@index([salesName])
  @@index([tradeMode, createdAt])
  @@index([status, createdAt])
  @@index([itemType, createdAt])
  @@index([itemCategoryId])
  @@index([itemBrandId])
  @@index([itemModelId])
  @@index([uomCategoryId])
  @@index([inventoryAccountId])
  @@index([cogsAccountId])
  @@index([incomeAccountId])
  @@map("accountingproduct")
}

// Per-branch stock-on-hand. One row per (productId, storeId) actually used.
// This replaces the legacy `accountingproduct.stockOnHand` global counter,
// which is kept in sync as a fallback during the rollout window and removed
// in a follow-up. New-critical-update-plan.md Phase 4.
model AccountingProductStock {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  qtyOnHand Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt DateTime @updatedAt

  product AccountingProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)

  @@unique([productId, storeId])
  @@index([productId])
  @@index([storeId])
  @@map("accountingproductstock")
}

model AccountingPurchaseOrder {
  id           String             @id @default(cuid())
  poNumber     String             @unique @db.VarChar(50)
  supplierId   String
  storeId      String
  supplierRef  String             @default("") @db.VarChar(100)
  buyerCode    String             @default("") @db.VarChar(50)
  poDate       DateTime           @db.Date
  expectedDate DateTime           @db.Date
  currency     String             @default("LKR") @db.VarChar(10)
  discount     Decimal            @default(0) @db.Decimal(18, 2)
  tax1Code     String?            @db.VarChar(30)
  tax1Name     String?            @db.VarChar(100)
  tax1Rate     Decimal?           @db.Decimal(14, 4)
  tax1Method   String?            @db.VarChar(20)
  tax1Amount   Decimal            @default(0) @db.Decimal(18, 4)
  tax2Code     String?            @db.VarChar(30)
  tax2Name     String?            @db.VarChar(100)
  tax2Rate     Decimal?           @db.Decimal(14, 4)
  tax2Method   String?            @db.VarChar(20)
  tax2Amount   Decimal            @default(0) @db.Decimal(18, 4)
  notes        String             @default("") @db.Text
  terms        String             @default("") @db.Text
  status       AccountingPoStatus @default(DRAFT)
  createdById  String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  supplier      AccountingSupplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  store         Store                         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy     AccountingUser                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lines         AccountingPurchaseOrderLine[]
  goodsReceipts AccountingGoodsReceipt[]

  @@index([supplierId])
  @@index([storeId])
