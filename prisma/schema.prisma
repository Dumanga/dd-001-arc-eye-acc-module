// ─── POS bill ────────────────────────────────────────────────────
// One entity covering live cart, held bill, posted bill, cancelled
// bill — discriminated by status + isHeld. Per
// accounting-theories.md § 7 POS Schema Implications and
// pos-integration-flow.md § 4.2.
//
// Lifecycle:
//   DRAFT, isHeld=false  - live cart being rung up by a cashier
//   DRAFT, isHeld=true   - held; reservations + billNo persist
//   COMPLETED            - posted to GL; settled (cash/card/mixed)
//                          or merchant-pending (split)
//   CANCELLED            - abandoned (auto-expired) or explicitly
//                          deleted before Pay; billNo burned
//
// Stock reservation: SUM(line.qty WHERE bill.status = DRAFT) for
// the productId at the storeId is subtracted from qtyOnHand for
// other cashiers' availability. See pos-integration-flow.md § 8.2.
//
// Bill numbers from form-id config (`POS` series) are assigned at
// row creation and never recycled — cancelled bills keep their
// billNo on the cancelled row, the next DRAFT takes the next
// sequential number. See § 8.4.
model AccountingPosBill {
  id     String                  @id @default(cuid())
  billNo String                  @unique @db.VarChar(50)
  status AccountingPosBillStatus @default(DRAFT)
  isHeld Boolean                 @default(false)

  storeId    String
  cashierId  String
  customerId String // Always set — walk-in row OR registered customer

  // Set only when paymentMethod = SPLIT — references an
  // isMerchant=true row in accountingclient.
  merchantClientId String?

  // Set on Pay, denormalised summary of how this bill was paid.
  // Detail breakdown lives on AccountingPosBillPayment.
  paymentMethod AccountingPosBillSummaryMethod?

  // The primary cash/cash-equivalent account picked at Pay time.
  // For MIXED bills this is the FIRST account selected (the second
  // is per-bill, not retained as default for next bill). The next
  // bill's POS screen reads this from the most-recent COMPLETED
  // bill at this branch. See § 8.6.
  primaryCashAccountId String?

  // Pricing snapshot at Pay time.
  subtotal      Decimal @default(0) @db.Decimal(18, 4)
  totalDiscount Decimal @default(0) @db.Decimal(18, 4)
  total         Decimal @default(0) @db.Decimal(18, 4)

  // Posting metadata (set on transition DRAFT → COMPLETED).
  postedAt  DateTime?
  postingId String? // Snapshot of the journal entry header id for traceability.

  // Cancellation metadata (set on transition to CANCELLED).
  cancelledAt  DateTime?
  cancelReason String?   @db.VarChar(80) // e.g. "auto-expired", "user-deleted"

  // Operational fields for hold + auto-expiry.
  heldAt         DateTime?
  heldNote       String?   @db.VarChar(200)
  lastActivityAt DateTime  @default(now())

  notes String @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store              Store                                 @relation(fields: [storeId], references: [id], onDelete: Restrict)
  cashier            AccountingUser                        @relation("PosBillCashier", fields: [cashierId], references: [id], onDelete: Restrict)
  customer           AccountingClient                      @relation("PosBillCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  merchantClient     AccountingClient?                     @relation("PosBillMerchant", fields: [merchantClientId], references: [id], onDelete: Restrict)
  primaryCashAccount ChartOfAccount?                       @relation("PosBillPrimaryCashAccount", fields: [primaryCashAccountId], references: [id], onDelete: Restrict)
  lines              AccountingPosBillLine[]
  payments           AccountingPosBillPayment[]
  customerReturns    AccountingCustomerReturn[]            @relation("CustomerReturnFromPosBill")
  paymentAllocations AccountingCustomerPaymentAllocation[] @relation("CustomerPaymentAllocationPosBill")

  @@index([storeId])
  @@index([cashierId])
  @@index([customerId])
  @@index([merchantClientId])
  @@index([status, createdAt])
  @@index([status, isHeld, lastActivityAt]) // for auto-expiry sweep
  @@index([postedAt])
  @@map("accountingposbill")
}

model AccountingPosBillLine {
  id     String @id @default(cuid())
  billId String

  productId   String
  itemCode    String @db.VarChar(60)
  itemName    String @db.VarChar(200)
  description String @default("") @db.VarChar(500)

  quantity  Decimal @db.Decimal(18, 4)
  unitPrice Decimal @db.Decimal(18, 4)
  // Always 0 for voucher lines per theory § 7.3.
  discount  Decimal @default(0) @db.Decimal(18, 4)
  lineTotal Decimal @db.Decimal(18, 4)

  uomName   String  @default("") @db.VarChar(100)
  uomBase   String  @default("") @db.VarChar(100)
  uomMinQty Decimal @default(1) @db.Decimal(18, 4)

  // Set when product itemType = VOUCHER — references the specific
  // serial being sold (from AccountingGoodsReceiptLineSerial). The
  // serial is "soft-locked" while this line lives in any DRAFT
  // bill, and transitions to ISSUED state when the bill goes
  // COMPLETED. ACTIVE-state filtering for the picker excludes
  // serials referenced by any DRAFT or COMPLETED bill line.
  voucherSerialId String?

  // Set when product itemType = INVENTORY_ITEM AND
  // product.serialTrackingEnabled = true. Same soft-lock semantics as
  // voucherSerialId — a serial referenced by any DRAFT or COMPLETED
  // bill is unavailable for selection on other bills. Qty is forced
  // to 1 for serial-tracked product lines (one bill line per serial).
  productSerialId String?

  lineOrder Int      @default(0)
  createdAt DateTime @default(now())

  posBill             AccountingPosBill                 @relation(fields: [billId], references: [id], onDelete: Cascade)
  product             AccountingProduct                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  voucherSerial       AccountingGoodsReceiptLineSerial? @relation("PosBillLineVoucherSerial", fields: [voucherSerialId], references: [id], onDelete: SetNull)
  productSerial       AccountingGoodsReceiptLineSerial? @relation("PosBillLineProductSerial", fields: [productSerialId], references: [id], onDelete: SetNull)
  customerReturnLines AccountingCustomerReturnLine[]    @relation("CustomerReturnFromPosBillLine")

  @@index([billId, lineOrder])
  @@index([productId])
  @@index([voucherSerialId])
  @@index([productSerialId])
  @@map("accountingposbillline")
}

// Tender rows. One bill may have multiple rows (MIXED = two CASH
// rows; future REDEEM_VOUCHER additions in next phase).
//
// Sum of amount across rows must equal bill.total at Pay time.
model AccountingPosBillPayment {
  id     String @id @default(cuid())
  billId String

  method AccountingPosBillTenderMethod

  // Required when method = CASH or CARD; null otherwise.
  cashAccountId String?

  // Required when method = SPLIT; null otherwise. References an
  // isMerchant=true row in accountingclient.
  merchantClientId String?

  // Required when method = REDEEM_VOUCHER; null otherwise. References
  // the voucher serial being redeemed (per theory § 7.4).
  voucherSerialId String?

  amount Decimal @db.Decimal(18, 4)

  rowOrder  Int      @default(0)
  createdAt DateTime @default(now())

  bill           AccountingPosBill                 @relation(fields: [billId], references: [id], onDelete: Cascade)
  cashAccount    ChartOfAccount?                   @relation("PosBillPaymentCashAccount", fields: [cashAccountId], references: [id], onDelete: Restrict)
  merchantClient AccountingClient?                 @relation("PosBillPaymentMerchant", fields: [merchantClientId], references: [id], onDelete: Restrict)
  voucherSerial  AccountingGoodsReceiptLineSerial? @relation("PosBillPaymentVoucherSerial", fields: [voucherSerialId], references: [id], onDelete: Restrict)

  @@index([billId, rowOrder])
  @@index([cashAccountId])
  @@index([merchantClientId])
  @@index([voucherSerialId])
  @@map("accountingposbillpayment")
}
