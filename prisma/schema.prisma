  @@index([expenseVoucherId, lineOrder])
  @@index([accountId])
  @@map("accountingexpensevoucherline")
}

// Journal Entry Voucher (JEV) — per accounting-theories.md §9. The catch-all
// manual posting tool: each line picks any account, each line carries
// either a debit OR a credit amount (not both), and the voucher must
// balance (∑Dr = ∑Cr) before it can be posted. No sub-ledger.
model AccountingJournalVoucher {
  id            String                         @id @default(cuid())
  voucherNumber String                         @unique @db.VarChar(50)
  storeId       String
  entryDate     DateTime                       @db.Date
  currency      String                         @default("LKR") @db.VarChar(10)
  description   String                         @default("") @db.VarChar(500)
  total         Decimal                        @default(0) @db.Decimal(18, 4)
  notes         String                         @default("") @db.Text
  status        AccountingJournalVoucherStatus @default(DRAFT)
  createdById   String
  postedById    String?
  postedAt      DateTime?
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  store     Store                          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy AccountingUser                 @relation("JournalVoucherCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  postedBy  AccountingUser?                @relation("JournalVoucherPostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  lines     AccountingJournalVoucherLine[]

  @@index([storeId])
  @@index([createdById])
  @@index([status, createdAt])
  @@index([entryDate])
  @@map("accountingjournalvoucher")
}

model AccountingJournalVoucherLine {
  id               String   @id @default(cuid())
  journalVoucherId String
  accountId        String
  debitAmount      Decimal  @default(0) @db.Decimal(18, 4)
  creditAmount     Decimal  @default(0) @db.Decimal(18, 4)
  memo             String   @default("") @db.VarChar(500)
  lineOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  journalVoucher AccountingJournalVoucher @relation(fields: [journalVoucherId], references: [id], onDelete: Cascade)
  account        ChartOfAccount           @relation("JournalVoucherLineAccount", fields: [accountId], references: [id], onDelete: Restrict)

  @@index([journalVoucherId, lineOrder])
  @@index([accountId])
  @@map("accountingjournalvoucherline")
}

// Material Issue Note (MIN) — per accounting-theories.md §10. Records
// inventory leaving the warehouse for internal consumption (repairs,
// maintenance, samples, write-offs). Cost is charged to a header-level
// expense account; inventory is credited at lifetime weighted-average cost.
// No supplier/customer ledger involvement.
model AccountingMaterialIssue {
  id               String                        @id @default(cuid())
  issueNumber      String                        @unique @db.VarChar(50)
  storeId          String
  expenseAccountId String
  issueDate        DateTime                      @db.Date
  currency         String                        @default("LKR") @db.VarChar(10)
  requestedBy      String                        @default("") @db.VarChar(150)
  purpose          String                        @default("") @db.VarChar(500)
  total            Decimal                       @default(0) @db.Decimal(18, 4)
  notes            String                        @default("") @db.Text
  status           AccountingMaterialIssueStatus @default(DRAFT)
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  store          Store                         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  expenseAccount ChartOfAccount                @relation("MaterialIssueExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)
  createdBy      AccountingUser                @relation("MaterialIssueCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy     AccountingUser?               @relation("MaterialIssueApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lines          AccountingMaterialIssueLine[]

  @@index([storeId])
  @@index([expenseAccountId])
  @@index([createdById])
  @@index([status, createdAt])
  @@index([issueDate])
  @@map("accountingmaterialissue")
}

model AccountingMaterialIssueLine {
  id              String   @id @default(cuid())
  materialIssueId String
  productId       String
  itemCode        String   @db.VarChar(60)
  itemName        String   @db.VarChar(200)
  description     String   @default("") @db.VarChar(500)
  // Quantity issued (qty leaving stock at the branch).
  quantity        Decimal  @db.Decimal(18, 4)
  // Snapshotted lifetime weighted-average cost at approval time.
  // Stored alongside the GL row so we can render the issue note later
