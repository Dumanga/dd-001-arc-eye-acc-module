  originalQty         Decimal                     @db.Decimal(18, 4)
  unitPrice           Decimal                     @db.Decimal(18, 4)
  returnQty           Decimal                     @db.Decimal(18, 4)
  lineGross           Decimal                     @default(0) @db.Decimal(18, 4)
  lineDiscount        Decimal                     @default(0) @db.Decimal(18, 4)
  lineNet             Decimal                     @default(0) @db.Decimal(18, 4)
  reason              AccountingGoodsReturnReason @default(OTHER)
  notes               String                      @default("") @db.VarChar(500)
  lineOrder           Int                         @default(0)
  createdAt           DateTime                    @default(now())

  customerReturn    AccountingCustomerReturn @relation(fields: [customerReturnId], references: [id], onDelete: Cascade)
  invoiceLine       AccountingInvoiceLine?   @relation(fields: [invoiceLineId], references: [id], onDelete: Restrict)
  sourcePosBillLine AccountingPosBillLine?   @relation("CustomerReturnFromPosBillLine", fields: [sourcePosBillLineId], references: [id], onDelete: Restrict)
  product           AccountingProduct        @relation(fields: [productId], references: [id], onDelete: Restrict)

