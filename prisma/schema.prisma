// Customer return source-document type. Per theory § 7 Returns,
// only INVOICE and SPLIT-method POS bills are returnable through
// this module — Cash/Card/Mixed POS bills are NOT returnable.
enum AccountingCustomerReturnSourceType {
  INVOICE
  POS_BILL
}

model AccountingCustomerReturn {
  id              String                             @id @default(cuid())
  returnNumber    String                             @unique @db.VarChar(50)
  // Source document discriminator. Existing rows default to INVOICE
  // via migration. Going forward, POS_BILL returns set sourcePosBillId
  // and sourcePosBillLineId (on lines) instead of invoiceId.
  sourceType      AccountingCustomerReturnSourceType @default(INVOICE)
  invoiceId       String? // null when sourceType = POS_BILL
  sourcePosBillId String? // set only when sourceType = POS_BILL
  customerId      String
  storeId         String
  returnDate      DateTime                           @db.Date
  returnedBy      String                             @default("") @db.VarChar(100)
  reasonHeader    String                             @default("") @db.VarChar(200)
  currency        String                             @default("LKR") @db.VarChar(10)
  notes           String                             @default("") @db.Text
  totalQty        Decimal                            @default(0) @db.Decimal(18, 4)
  totalGross      Decimal                            @default(0) @db.Decimal(18, 4)
  totalDiscount   Decimal                            @default(0) @db.Decimal(18, 4)
  totalNet        Decimal                            @default(0) @db.Decimal(18, 4)
  status          AccountingCustomerReturnStatus     @default(DRAFT)
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime                           @default(now())
  updatedAt       DateTime                           @updatedAt

  invoice       AccountingInvoice?             @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  sourcePosBill AccountingPosBill?             @relation("CustomerReturnFromPosBill", fields: [sourcePosBillId], references: [id], onDelete: Restrict)
  customer      AccountingClient               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  store         Store                          @relation(fields: [storeId], references: [id], onDelete: Restrict)
  createdBy     AccountingUser                 @relation("CustomerReturnCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy    AccountingUser?                @relation("CustomerReturnApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  lines         AccountingCustomerReturnLine[]

  @@index([invoiceId])
  @@index([sourcePosBillId])
  @@index([sourceType])
  @@index([customerId])
  @@index([storeId])
  @@index([createdById])
  @@index([status, createdAt])
  @@index([returnDate])
  @@map("accountingcustomerreturn")
}

model AccountingCustomerReturnLine {
  id                  String                      @id @default(cuid())
  customerReturnId    String
  // For sourceType=INVOICE returns
  invoiceLineId       String?
  // For sourceType=POS_BILL returns (SPLIT-method only per theory § 7)
  sourcePosBillLineId String?
  productId           String
  itemCode            String                      @db.VarChar(60)
  itemName            String                      @db.VarChar(200)
  description         String                      @default("") @db.VarChar(500)
  uomName             String                      @default("") @db.VarChar(100)
