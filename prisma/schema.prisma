  unitCost        Decimal  @default(0) @db.Decimal(18, 4)
  lineValue       Decimal  @default(0) @db.Decimal(18, 4)
  uomName         String   @default("") @db.VarChar(100)
  uomBase         String   @default("") @db.VarChar(100)
  notes           String   @default("") @db.VarChar(500)
  lineOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  materialIssue AccountingMaterialIssue @relation(fields: [materialIssueId], references: [id], onDelete: Cascade)
  product       AccountingProduct       @relation("MaterialIssueLineProduct", fields: [productId], references: [id], onDelete: Restrict)

  @@index([materialIssueId, lineOrder])
  @@index([productId])
  @@map("accountingmaterialissueline")
}

