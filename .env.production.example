# Production env template — copy this to `.env` on the VPS and fill in.
# `.env` is git-ignored, so the real secrets never leave the server.

# ── MySQL container creds ──────────────────────────────────────────────
# These configure the `db` service inside docker-compose. Pick a long,
# random password for MYSQL_ROOT_PASSWORD — it never leaves the docker
# network.
MYSQL_ROOT_PASSWORD=change-me-to-a-long-random-string
MYSQL_DATABASE=arceye_acc_module

# ── App connection to the DB ───────────────────────────────────────────
# Hostname `db` is the docker-compose service name. URL-encode any
# special characters in the password (e.g. `#` → `%23`).
DATABASE_URL=mysql://root:change-me-to-a-long-random-string@db:3306/arceye_acc_module

# ── Public base URL ────────────────────────────────────────────────────
# This is baked into the Next.js client bundle at build time, so changing
# it requires a rebuild (docker compose build app).
NEXT_PUBLIC_BASE_URL=https://arceyedc.com
